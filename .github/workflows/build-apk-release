name: Build Signed Android APK (Release)

on:
  push:
    branches: [ main, develop ]
  pull_request:
    branches: [ main ]

jobs:
  build:
    runs-on: ubuntu-latest

    steps:
      - name: Checkout code
        uses: actions/checkout@v4

      - name: Set up JDK 17
        uses: actions/setup-java@v4
        with:
          distribution: 'temurin'
          java-version: '17'

      - name: Setup Gradle
        uses: gradle/actions/setup-gradle@v3
        with:
          gradle-version: "8.2"

      - name: Generate Gradle Wrapper
        run: |
          cd android-tv
          gradle wrapper

      - name: Copy icon to mipmap directories
        run: |
          mkdir -p android-tv/app/src/main/res/mipmap-hdpi
          mkdir -p android-tv/app/src/main/res/mipmap-mdpi
          mkdir -p android-tv/app/src/main/res/mipmap-xhdpi
          mkdir -p android-tv/app/src/main/res/mipmap-xxhdpi
          mkdir -p android-tv/app/src/main/res/mipmap-xxxhdpi
          cp public/icon.png android-tv/app/src/main/res/mipmap-hdpi/ic_launcher.png
          cp public/icon.png android-tv/app/src/main/res/mipmap-mdpi/ic_launcher.png
          cp public/icon.png android-tv/app/src/main/res/mipmap-xhdpi/ic_launcher.png
          cp public/icon.png android-tv/app/src/main/res/mipmap-xxhdpi/ic_launcher.png
          cp public/icon.png android-tv/app/src/main/res/mipmap-xxxhdpi/ic_launcher.png

      - name: Decode Keystore
        run: |
          echo "${{ secrets.KEYSTORE_BASE64 }}" | base64 --decode > android-tv/keystore.jks

      - name: Grant execute permission for gradlew
        run: chmod +x android-tv/gradlew

      - name: Build Signed Release APK
        run: |
          cd android-tv
          ./gradlew assembleRelease \
            -Pandroid.injected.signing.store.file=keystore.jks \
            -Pandroid.injected.signing.store.password=${{ secrets.KEYSTORE_PASSWORD }} \
            -Pandroid.injected.signing.key.alias=${{ secrets.KEY_ALIAS }} \
            -Pandroid.injected.signing.key.password=${{ secrets.KEY_PASSWORD }}

      - name: Upload Release APK artifact
        uses: actions/upload-artifact@v4
        with:
          name: app-release-apk
          path: android-tv/app/build/outputs/apk/release/*.apk
